import javax.swing.JOptionPane;
import javax.swing.JFrame;

public class earlliee {
    public static void main(String[] args) {
        JFrame frame = new JFrame();
        frame.setAlwaysOnTop(true);

        JOptionPane.showMessageDialog(frame, "Pero what if...", "Message", JOptionPane.INFORMATION_MESSAGE);
        JOptionPane.showMessageDialog(frame, "Pero what if", "Message", JOptionPane.INFORMATION_MESSAGE);
        JOptionPane.showMessageDialog(frame, "Kaya ko naman pala talaga na wala siya", "Message", JOptionPane.INFORMATION_MESSAGE);
        JOptionPane.showMessageDialog(frame, "Akala ko dati kasi", "Message", JOptionPane.INFORMATION_MESSAGE);
        JOptionPane.showMessageDialog(frame, "Pag nawala siya ", "Message", JOptionPane.INFORMATION_MESSAGE);
        JOptionPane.showMessageDialog(frame, "Hindi ko kakayanin", "Message", JOptionPane.INFORMATION_MESSAGE);
        JOptionPane.showMessageDialog(frame, "Pero alam mo", "Message", JOptionPane.INFORMATION_MESSAGE);
        JOptionPane.showMessageDialog(frame, "Mula nung nawala ka", "Message", JOptionPane.INFORMATION_MESSAGE);
        JOptionPane.showMessageDialog(frame, "Marami din naman akong natutunan", "Message", JOptionPane.INFORMATION_MESSAGE);

        String[] options = {
            "Kaya mo rin ba?",
            "May naalala ka?"
        };

        JOptionPane.showOptionDialog(
            frame,
            "Ikaw... kamusta ka na ngayon?",
            "Message",
            JOptionPane.DEFAULT_OPTION,
            JOptionPane.INFORMATION_MESSAGE,
            null,
            options,
            options[0]
        );

        frame.dispose();
        System.exit(0);
    }
}
