import javax.swing.JOptionPane;
import javax.swing.JFrame;

public class earlliee {
    public static void main(String[] args) {
        JFrame frame = new JFrame();
        frame.setAlwaysOnTop(true);

        JOptionPane.showMessageDialog(frame, "Okay guys", "Message", JOptionPane.INFORMATION_MESSAGE);
        JOptionPane.showMessageDialog(frame, "Quiz tayo", "Message", JOptionPane.INFORMATION_MESSAGE);
        JOptionPane.showMessageDialog(frame, "Be honest", "Message", JOptionPane.INFORMATION_MESSAGE);
        JOptionPane.showMessageDialog(frame, "Nung time na nag-oopen up ka sa kanya", "Message", JOptionPane.INFORMATION_MESSAGE);

        String[] options = {"Hindi", "Akala ko oo"};

        JOptionPane.showOptionDialog(
            frame,
            "Pinakinggan ka ba talaga niya?",
            "Message",
            JOptionPane.DEFAULT_OPTION,
            JOptionPane.INFORMATION_MESSAGE,
            null,
            options,
            options[0]
        );

        frame.dispose();
        System.exit(0);
    }
}
